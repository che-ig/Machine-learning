# Use a super fast index for search instead of the mupdf's implementation
super_fast_search 1

# поиск с без учета регистра
case_sensitive_search 0

# цвет статус бара
status_bar_color 0.2 0.2 0.2

# Цвета
search_highlight_color 0.5 0.7 0.95     # Цвет подсветки поиска (желтый)
link_highlight_color 0.55 0.85 0.55       # Цвет подсветки ссылок (зеленый)

# открываем каждый файл в новом окне
should_launch_new_window 1

status_bar_color        0.04 0.3 0.54
status_bar_text_color   1 0.9 0.41
status_bar_font_size    14
